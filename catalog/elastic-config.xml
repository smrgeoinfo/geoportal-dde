<?xml version="1.0" encoding="UTF-8"?>
<!-- Elasticsearch connection settings for Geoportal Catalog.
     Mounted into the WAR's config directory. -->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

  <!-- Primary Elasticsearch connection -->
  <bean id="elasticConfig" class="com.esri.geoportal.lib.elastic.ElasticConfig">
    <property name="httpHost" value="elasticsearch"/>
    <property name="httpPort" value="9200"/>
    <property name="httpScheme" value="http"/>
    <!-- No authentication needed for dev; set these for production -->
    <!-- <property name="username" value=""/> -->
    <!-- <property name="password" value=""/> -->
  </bean>

</beans>
